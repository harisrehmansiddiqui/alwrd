generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AudienceType {
  group
  family
  couple
}

enum Tier {
  economy
  standard
  premium
}

enum InquiryStatus {
  new
  high_quality_lead
  contacted
  confirmed
  closed
  lost
}

enum ResourceType {
  dua
  checklist
  blog
}

enum AdminRole {
  super_admin
  agent
}

model Package {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  audience     AudienceType
  tier         Tier
  tagline      String
  description  String?      @db.Text
  image        String
  gallery      Json?
  amenities    Json
  inclusions   Json?
  itinerary    Json?
  makkahHotel  String?
  madinahHotel String?
  haramDist    String?
  metaTitle    String?
  metaDesc     String?
  featured     String?
  active       Boolean      @default(true)
  departures   Departure[]
  inquiries    Inquiry[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([active, tier, audience])
}

model Departure {
  id            String    @id @default(cuid())
  package       Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId     String
  departureDate DateTime
  city          String
  durationDays  Int
  durationNights Int
  price         Int
  oldPrice      Int?
  seats         Int       @default(0)
  active        Boolean   @default(true)
  inquiries     Inquiry[]
  createdAt     DateTime  @default(now())

  @@index([active, departureDate, city])
}

model Inquiry {
  id              String        @id @default(cuid())
  reference       String        @unique
  travelerName    String
  phone           String
  email           String
  passportNumber  String?
  travelDate      String?
  groupSize       Int           @default(1)
  specialRequests String?       @db.Text
  status          InquiryStatus @default(new)
  notes           Json?
  assignedTo      String?
  package         Package?      @relation(fields: [packageId], references: [id])
  packageId       String?
  departure       Departure?    @relation(fields: [departureId], references: [id])
  departureId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, createdAt])
}

model AdminUser {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  passwordHash String
  role      AdminRole @default(agent)
  createdAt DateTime  @default(now())
}

model Banner {
  id          String  @id @default(cuid())
  headline    String?
  ctaLabel    String?
  ctaHref     String?
  imageDesktop String
  imageMobile  String?
  sortOrder   Int     @default(0)
  active      Boolean @default(true)
}

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  city      String?
  rating    Int     @default(5)
  quote     String  @db.Text
  videoUrl  String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}

model Highlight {
  id        String  @id @default(cuid())
  title     String
  description String
  icon      String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}

model PartnerLogo {
  id        String  @id @default(cuid())
  name      String
  logo      String?
  url       String?
  sortOrder Int     @default(0)
}

model TrustStat {
  id        String @id @default(cuid())
  label     String
  value     String
  sortOrder Int    @default(0)
}

model Resource {
  id        String       @id @default(cuid())
  slug      String       @unique
  type      ResourceType
  title     String
  body      String       @db.Text
  metaTitle String?
  metaDesc  String?
  published Boolean      @default(true)
  createdAt DateTime     @default(now())
}

model Faq {
  id        String  @id @default(cuid())
  question  String
  answer    String  @db.Text
  category  String?
  sortOrder Int     @default(0)
}

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String   @db.Text
  updatedAt DateTime @updatedAt
}

model IntegrationModule {
  id      String  @id @default(cuid())
  key     String  @unique
  enabled Boolean @default(false)
  config  Json?
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}
